# ─── Database ────────────────────────────────────────────────────────
# Supabase pooler. IMPORTANT port choice:
#   - Local dev + migrations: SESSION pooler, port 5432 (supports prepared
#     statements / advisory locks that `prisma migrate` needs).
#   - Vercel / serverless runtime: TRANSACTION pooler, port 6543 (multiplexes
#     many short-lived connections; avoids session-pool exhaustion → 500s).
# Same host/credentials, only the port differs. Set 6543 in Vercel env vars.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ─── Auth ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── Email (Resend) ──────────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="Ušetri <info@usetri.sk>"

# ─── Storage (Supabase Storage / S3-compatible) ──────────────────────
STORAGE_URL=""
STORAGE_BUCKET="usetri"
STORAGE_ACCESS_KEY=""
STORAGE_SECRET_KEY=""

# ─── AI extraction ───────────────────────────────────────────────────
# Provider: "anthropic" | "openai" (see src/server/services/extraction)
EXTRACTION_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# ─── Cache / rate limiting (Upstash Redis) ───────────────────────────
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Background jobs (Inngest) ───────────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ─── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
